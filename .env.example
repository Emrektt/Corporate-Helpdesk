# ─── PostgreSQL Veritabanı ───
POSTGRES_DB=helpdesk
POSTGRES_USER=helpdesk_user
POSTGRES_PASSWORD=SuperSecretPassword123!

# ─── MSAL (Microsoft Entra ID) Ayarları ───
# Backend için:
TENANT_ID=your-tenant-id
BACKEND_CLIENT_ID=your-backend-client-id

# Frontend için (VITE_ ile başlamalı):
VITE_MSAL_TENANT_ID=your-tenant-id
VITE_MSAL_CLIENT_ID=your-frontend-client-id
VITE_MSAL_REDIRECT_URI=http://localhost
VITE_MSAL_API_SCOPE=api://your-backend-client-id/User.Read
