generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model alembic_version {
  version_num String @id(map: "alembic_version_pkc") @db.VarChar(32)
}

model articles {
  id            Int         @id @default(autoincrement())
  title         String      @db.VarChar
  content       String
  department_id Int
  is_published  Boolean?
  view_count    Int?
  created_by_id Int
  created_at    DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?   @db.Timestamptz(6)
  users         users       @relation(fields: [created_by_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  departments   departments @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_articles_id")
  @@index([title], map: "ix_articles_title")
}

model canned_responses {
  id            Int       @id @default(autoincrement())
  title         String    @db.VarChar
  content       String    @db.VarChar
  category      String?   @db.VarChar
  is_active     Boolean?
  created_by_id Int
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @db.Timestamptz(6)
  users         users     @relation(fields: [created_by_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_canned_responses_id")
  @@index([title], map: "ix_canned_responses_title")
}

model categories {
  id               Int            @id @default(autoincrement())
  name             String         @db.VarChar
  department_id    Int
  default_priority prioritylevel?
  is_active        Boolean?
  created_at       DateTime?      @default(now()) @db.Timestamptz(6)
  departments      departments    @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tickets          tickets[]

  @@index([id], map: "ix_categories_id")
  @@index([name], map: "ix_categories_name")
}

model chat_messages {
  id              Int        @id @default(autoincrement())
  room_id         Int
  sender_id       Int
  content         String
  is_system       Boolean?
  created_at      DateTime?  @default(now()) @db.Timestamptz(6)
  attachment_url  String?    @db.VarChar
  attachment_type String?    @db.VarChar
  attachment_name String?    @db.VarChar
  chat_rooms      chat_rooms @relation(fields: [room_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users           users      @relation(fields: [sender_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_chat_messages_id")
}

model chat_rooms {
  id                               Int             @id @default(autoincrement())
  user_id                          Int
  agent_id                         Int?
  status                           chatroomstatus?
  subject                          String?         @db.VarChar
  created_at                       DateTime?       @default(now()) @db.Timestamptz(6)
  closed_at                        DateTime?       @db.Timestamptz(6)
  chat_messages                    chat_messages[]
  users_chat_rooms_agent_idTousers users?          @relation("chat_rooms_agent_idTousers", fields: [agent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_chat_rooms_user_idTousers  users           @relation("chat_rooms_user_idTousers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_chat_rooms_id")
}

model departments {
  id          Int          @id @default(autoincrement())
  name        String       @unique(map: "ix_departments_name") @db.VarChar
  description String?      @db.VarChar
  is_active   Boolean?
  created_at  DateTime?    @default(now()) @db.Timestamptz(6)
  articles    articles[]
  categories  categories[]
  tickets     tickets[]
  users       users[]

  @@index([id], map: "ix_departments_id")
}

model events {
  id          Int       @id @default(autoincrement())
  level       String?   @db.VarChar
  source      String?   @db.VarChar
  event_type  String?   @db.VarChar
  message     String
  stack_trace String?
  user_id     Int?
  user_email  String?   @db.VarChar
  user_name   String?   @db.VarChar
  ip_address  String?   @db.VarChar
  user_agent  String?
  created_at  DateTime? @db.Timestamp(6)
  users       users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([event_type], map: "ix_events_event_type")
  @@index([id], map: "ix_events_id")
  @@index([level], map: "ix_events_level")
  @@index([source], map: "ix_events_source")
}

model notifications {
  id                Int       @id @default(autoincrement())
  recipient_user_id Int
  ticket_id         Int?
  title             String    @db.VarChar
  message           String    @db.VarChar
  is_read           Boolean?
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  users             users     @relation(fields: [recipient_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tickets           tickets?  @relation(fields: [ticket_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_notifications_id")
}

model ticket_attachments {
  id             Int       @id @default(autoincrement())
  ticket_id      Int
  uploaded_by_id Int
  file_name      String    @db.VarChar
  file_path      String    @db.VarChar
  content_type   String    @db.VarChar
  size           Int
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  tickets        tickets   @relation(fields: [ticket_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users          users     @relation(fields: [uploaded_by_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_ticket_attachments_id")
}

model ticket_comments {
  id          Int       @id @default(autoincrement())
  ticket_id   Int
  user_id     Int
  message     String    @db.VarChar
  is_internal Boolean?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  tickets     tickets   @relation(fields: [ticket_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users       users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_ticket_comments_id")
}

model ticket_history {
  id            Int        @id @default(autoincrement())
  ticket_id     Int
  actor_user_id Int
  action        actiontype
  old_value     String?    @db.VarChar
  new_value     String?    @db.VarChar
  created_at    DateTime?  @default(now()) @db.Timestamptz(6)
  users         users      @relation(fields: [actor_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tickets       tickets    @relation(fields: [ticket_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_ticket_history_id")
}

model tickets {
  id                                  Int                  @id @default(autoincrement())
  ticket_number                       String               @unique(map: "ix_tickets_ticket_number") @db.VarChar
  title                               String               @db.VarChar
  description                         String               @db.VarChar
  status                              ticketstatus
  priority                            prioritylevel
  category_id                         Int
  department_id                       Int
  created_by_id                       Int
  assigned_to_id                      Int?
  created_at                          DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at                          DateTime?            @db.Timestamptz(6)
  resolved_at                         DateTime?            @db.Timestamptz(6)
  due_at                              DateTime?            @db.Timestamptz(6)
  csat_score                          Int?
  csat_comment                        String?
  csat_submitted_at                   DateTime?            @db.Timestamptz(6)
  notifications                       notifications[]
  ticket_attachments                  ticket_attachments[]
  ticket_comments                     ticket_comments[]
  ticket_history                      ticket_history[]
  users_tickets_assigned_to_idTousers users?               @relation("tickets_assigned_to_idTousers", fields: [assigned_to_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  categories                          categories           @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_tickets_created_by_idTousers  users                @relation("tickets_created_by_idTousers", fields: [created_by_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  departments                         departments          @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_tickets_id")
}

model user_preferences {
  id                    Int      @id @default(autoincrement())
  user_id               Int      @unique
  email_notifications   Boolean
  desktop_notifications Boolean
  theme                 String   @db.VarChar(20)
  language              String   @db.VarChar(10)
  created_at            DateTime @db.Timestamp(6)
  updated_at            DateTime @db.Timestamp(6)
  users                 users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([id], map: "ix_user_preferences_id")
}

model users {
  id                                    Int                  @id @default(autoincrement())
  entra_object_id                       String?              @unique(map: "ix_users_entra_object_id") @db.VarChar
  email                                 String               @unique(map: "ix_users_email") @db.VarChar
  full_name                             String               @db.VarChar
  role                                  userrole
  department_id                         Int?
  is_active                             Boolean?
  created_at                            DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at                            DateTime?            @db.Timestamptz(6)
  articles                              articles[]
  canned_responses                      canned_responses[]
  chat_messages                         chat_messages[]
  chat_rooms_chat_rooms_agent_idTousers chat_rooms[]         @relation("chat_rooms_agent_idTousers")
  chat_rooms_chat_rooms_user_idTousers  chat_rooms[]         @relation("chat_rooms_user_idTousers")
  events                                events[]
  notifications                         notifications[]
  ticket_attachments                    ticket_attachments[]
  ticket_comments                       ticket_comments[]
  ticket_history                        ticket_history[]
  tickets_tickets_assigned_to_idTousers tickets[]            @relation("tickets_assigned_to_idTousers")
  tickets_tickets_created_by_idTousers  tickets[]            @relation("tickets_created_by_idTousers")
  user_preferences                      user_preferences?
  departments                           departments?         @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_users_id")
}

enum actiontype {
  TICKET_CREATED
  STATUS_CHANGED
  PRIORITY_CHANGED
  ASSIGNED
  COMMENT_ADDED
  TICKET_RESOLVED
}

enum chatroomstatus {
  ACTIVE
  CLOSED
}

enum prioritylevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ticketstatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  WAITING_FOR_USER
  RESOLVED
  CLOSED
  CANCELLED
}

enum userrole {
  ADMIN
  BACKEND_DEV
  FRONTEND_DEV
  SCRUM_MASTER
  TESTER
  DEVOPS
  PRODUCT_OWNER
  SUPPORT_AGENT
}
